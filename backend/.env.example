# Option A — Supabase / any PostgreSQL (single connection string)
DATABASE_URL=postgres://postgres:your_password@db.xxxx.supabase.co:5432/postgres

# Option B — individual vars (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password_here
DB_NAME=hospital_db
DB_SSL=true

JWT_SECRET=your_jwt_secret_here
PORT=4001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
